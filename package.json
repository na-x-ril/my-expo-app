    "expo-constants": "~55.0.7",
    "expo-image": "~55.0.5",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.3",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
